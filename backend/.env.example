# LankaCommerce — Django Backend Environment Variables
# ─────────────────────────────────────────────────────
# Copy this file to backend/.env and fill in the values for your local environment.
# NEVER commit backend/.env to source control — it is gitignored.

# ── Database ─────────────────────────────────────────────────────────────────
# Individual PostgreSQL connection parameters read by python-decouple.
DB_NAME=lanka_commerce_dev
DB_USER=your_postgres_username
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432

# ── Django Core ───────────────────────────────────────────────────────────────
# Generate SECRET_KEY with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-django-secret-key-here
# Set to True for development, False for production
DEBUG=True
# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1
# Django settings module — use config.settings.development locally, config.settings.production in production
DJANGO_SETTINGS_MODULE=config.settings.development

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL(s) of the Next.js frontend allowed to make cross-origin requests to this API
# Comma-separated for multiple origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Authentication (SimpleJWT) ────────────────────────────────────────────────
# Access token lifetime in minutes (default: 60)
ACCESS_TOKEN_LIFETIME_MINUTES=60
# Refresh token lifetime in days (default: 7)
REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Super Admin Seed ──────────────────────────────────────────────────────────
# Used by: python manage.py seed_superadmin (or: make seed-superadmin)
# IMPORTANT: Override these in production with strong values.
SEED_SUPERADMIN_EMAIL=superadmin@lankacommerce.dev
SEED_SUPERADMIN_PASSWORD=changeme123!

# ── Sample Tenant Seed ────────────────────────────────────────────────────────
# Used by: python manage.py seed_sample_tenant (or: make seed-sample-tenant)
# Must also set SEED_SAMPLE_TENANT=true (inline env or export) to enable.
SEED_OWNER_EMAIL=owner@dilani.example.com
SEED_OWNER_PASSWORD=OwnerPassword1!

# ── Cache / Redis (Production) ────────────────────────────────────────────────
# Used by throttling and session caching in production.
REDIS_URL=redis://localhost:6379/1

# ── File Storage ──────────────────────────────────────────────────────────────
# Provider to use for product image uploads. Valid values: supabase, cloudinary
# Defaults to "supabase" if absent or unrecognised.
STORAGE_PROVIDER=supabase

# Supabase Storage — service-role key is server-side only; NEVER expose to the browser
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=product-images

# Cloudinary — API secret is server-side only; NEVER expose to the browser
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── CRM / Cron ───────────────────────────────────────────────────────────────
CRON_SECRET=your-strong-random-secret-here

# ── Next.js Revalidation (Phase 10) ──────────────────────────────────────────
# Full URL of the Next.js revalidation endpoint — same origin as the frontend.
# In local dev: http://localhost:3000/api/revalidate
# In production: https://lankacommerce.com/api/revalidate
NEXT_REVALIDATION_URL=http://localhost:3000/api/revalidate
# Secret shared between Django and Next.js. Must match REVALIDATION_SECRET in frontend/.env.local
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
REVALIDATION_SECRET=your-strong-random-revalidation-secret-here

# ── Stripe Payment Gateway ────────────────────────────────────────────────────
# Get your keys from: https://dashboard.stripe.com/apikeys
# Use test keys (pk_test_... / sk_test_...) for development; live keys for production.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook signing secrets — get from Stripe Dashboard → Webhooks.
# Create two webhook endpoints in Stripe:
#   1. Platform billing:  https://your-api.com/api/billing/webhooks/stripe/
#   2. Webstore orders:   https://your-api.com/api/webstore/webhooks/stripe/
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_WEBSTORE_WEBHOOK_SECRET=whsec_...
# true for test mode, false for live (informational only — actual mode determined by key prefix)
STRIPE_SANDBOX=true

# ── Frontend / Webstore URLs ─────────────────────────────────────────────────
# Base URL of the Next.js frontend — used for Stripe success/cancel redirect URLs.
FRONTEND_APP_URL=http://localhost:3000
# Webstore base URL template. {slug} is replaced at runtime.
# Local dev: http://localhost:3000  (single-tenant, slug unused)
# Production: https://{slug}.lankacommerce.com
WEBSTORE_BASE_URL=http://localhost:3000
# Base URL of the Django API — used for notify/webhook URLs.
APP_URL=http://localhost:8000
